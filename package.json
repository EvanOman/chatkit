{
  "name": "chatkit",
  "version": "0.1.0",
  "type": "module",
  "description": "Reusable Web Components chat UI with SSE streaming",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    },
    "./sse": {
      "types": "./dist/sse/sse-client.d.ts",
      "import": "./dist/sse/sse-client.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./theme/chatkit.css": "./dist/theme/chatkit.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/register.js"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dompurify": "^3.2.0",
    "streaming-markdown": "^0.2.15"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.0.0",
    "jsdom": "^25.0.0"
  }
}
